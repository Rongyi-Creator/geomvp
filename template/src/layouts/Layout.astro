---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import businessData from '../data/business.json';

interface Props {
  title: string;
  description: string;
  pageType?: 'home' | 'service' | 'faq' | 'contact' | 'about' | 'prices';
  serviceData?: { name: string; description: string };
  faqItems?: Array<{ question: string; answer: string }>;
  noindex?: boolean;
  canonicalUrl?: string;
}

const {
  title,
  description,
  pageType = 'home',
  serviceData,
  faqItems,
  noindex = false,
  canonicalUrl,
} = Astro.props;

const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={businessData.name} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- JSON-LD -->
    <JsonLd pageType={pageType} serviceData={serviceData} faqItems={faqItems} />
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
